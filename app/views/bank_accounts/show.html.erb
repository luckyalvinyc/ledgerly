<%= render "shared/crumbs",
  trail: [["Dashboard", root_path], [@bank_account.name, @bank_account]] %>

<%= turbo_frame_tag @bank_account do %>
  <div class="page-head">
    <div class="titles">
      <h1><%= @bank_account.name %></h1>
      <p class="muted"><%= @bank_account.currency %> · <%= pluralize(@page.count, "transaction") %></p>
    </div>

    <div class="actions">
      <% if @page.count.positive? %>
        <%= link_to "View profit and loss",
          bank_account_profit_and_loss_path(@bank_account),
          class: "btn btn-primary" %>
        <%= link_to "Import transactions",
          new_bank_account_import_path(@bank_account),
          class: "btn" %>
      <% end %>
      <%= link_to edit_bank_account_path(@bank_account), class: "icon-btn", aria: { label: "Edit account name" } do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>
        </svg>
      <% end %>
      <%= button_to @bank_account,
        method: :delete,
        class: "icon-btn icon-danger",
        data: { turbo_confirm: "Delete #{@bank_account.name} and its #{pluralize(@page.count, "transaction")}? This cannot be undone." },
        aria: { label: "Delete account" } do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h18"/>
          <path d="M8 6V4h8v2"/>
          <path d="M6 6l1 14h10l1-14"/>
        </svg>
      <% end %>
    </div>
  </div>
<% end %>

<% if @page.count.positive? %>
  <table class="pnl-transactions">
    <thead>
      <tr>
        <th class="date">Date</th>
        <th>Description</th>
        <th class="amount">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% @page.records.each do |transaction| %>
        <tr>
          <td class="date"><%= transaction.posted_on.strftime("%d %b %Y") %></td>
          <td><%= transaction.description %></td>
          <%= tag.td class: class_names("amount", "is-negative" => transaction.amount.negative?) do %>
            <%= money(transaction.amount, currency: @bank_account.currency) %>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= render "shared/pager", page: @page %>
<% else %>
  <div class="card empty">
    <h2>No transactions yet</h2>
    <p class="muted">Import a CSV statement from your bank to see your profit.</p>
    <div class="actions">
      <%= link_to "Import your first statement",
        new_bank_account_import_path(@bank_account),
        class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
