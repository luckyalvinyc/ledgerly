<%= render "shared/crumbs",
  trail: [["Dashboard", root_path], [@bank_account.name, @bank_account]] %>

<%= turbo_frame_tag @bank_account do %>
  <div class="page-head">
    <div class="titles">
      <h1><%= @bank_account.name %></h1>
    </div>

    <div class="actions">
      <% if @page.count.positive? %>
        <%= link_to "View profit and loss",
          bank_account_profit_and_loss_path(@bank_account),
          class: "btn btn-primary",
          data: { turbo_frame: "_top" } %>
        <%= link_to "Import transactions",
          new_bank_account_import_path(@bank_account),
          class: "btn",
          data: { turbo_frame: "_top" } %>
      <% end %>

      <button type="button" class="icon-btn menu-btn" popovertarget="account_menu" aria-label="More actions">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="12" cy="5" r="1.6"/>
          <circle cx="12" cy="12" r="1.6"/>
          <circle cx="12" cy="19" r="1.6"/>
        </svg>
      </button>
      <div id="account_menu" popover class="menu-items">
        <% if @page.count.positive? %>
          <%= link_to "Export CSV", bank_account_path(@bank_account, format: :csv), data: { turbo: false } %>
        <% end %>
        <%= link_to "Edit name", edit_bank_account_path(@bank_account), data: { turbo_frame: dom_id(@bank_account) } %>
        <%= button_to "Delete account", @bank_account,
          method: :delete,
          class: "danger",
          form: { data: { turbo_frame: "_top", turbo_confirm: "Delete #{@bank_account.name} and its #{pluralize(@page.count, "transaction")}? This cannot be undone." } } %>
      </div>
    </div>
  </div>
<% end %>

<p class="account-meta"><span class="pill"><%= @bank_account.currency %></span></p>

<% if @page.count.positive? %>
  <h2 class="section-head">
    Transactions
    <span class="count"><%= pluralize(@page.count, "transaction") %></span>
  </h2>
  <table class="transactions-table">
    <thead>
      <tr>
        <th class="date">Date</th>
        <th>Description</th>
        <th class="amount">Amount</th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "shared/transaction",
        collection: @page.records,
        locals: { currency: @bank_account.currency } %>
    </tbody>
  </table>

  <%= render "shared/pager", page: @page %>
<% else %>
  <div class="card empty">
    <h2>No transactions yet</h2>
    <p class="muted">Import a CSV statement from your bank to see your profit.</p>
    <div class="actions">
      <%= link_to "Import your first statement",
        new_bank_account_import_path(@bank_account),
        class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
