<div class="password-field" data-controller="password">
  <%= form.password_field :password,
        required: true,
        autocomplete: autocomplete,
        data: { password_target: "input" } %>
  <button type="button"
          class="password-toggle"
          data-password-target="toggle"
          data-action="password#toggle"
          aria-label="Show password"
          aria-pressed="false">
    <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9.88 4.24A9.6 9.6 0 0 1 12 4c6.5 0 10 8 10 8a18.8 18.8 0 0 1-2.16 3.19M6.6 6.6A18.8 18.8 0 0 0 2 12s3.5 7 10 7a9.6 9.6 0 0 0 4.12-.88"/>
      <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>
      <line x1="2" y1="2" x2="22" y2="22"/>
    </svg>
  </button>
</div>
