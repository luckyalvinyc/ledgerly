<!DOCTYPE html>
<html lang="en"<%= raw(%( data-theme="#{current_theme}")) if current_theme %>>
  <%= render "layouts/shared/head" %>

  <body class="auth">
    <%= render "shared/theme_toggle" %>
    <section class="auth-pitch">
      <div class="auth-pitch-inner">
        <p class="brand">
          <%= render "shared/brand_mark" %>
          <span>Ledgerly</span>
        </p>
        <h1>Your money, in plain language.</h1>
        <p class="lede">Upload a bank statement, see your profit at a glance. No finance degree required.</p>
      </div>
    </section>
    <section class="auth-form">
      <div class="auth-form-inner">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    </section>
  </body>
</html>
