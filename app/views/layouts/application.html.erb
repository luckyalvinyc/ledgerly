<!DOCTYPE html>
<html lang="en"<%= raw(%( data-theme="#{current_theme}")) if current_theme %>>
  <%= render "layouts/shared/head" %>

  <body>
    <header class="site-header">
      <div class="bar">
        <%= link_to root_path, class: "brand" do %>
          <%= render "shared/brand_mark" %>
          <span>Ledgerly</span>
        <% end %>
        <div class="bar-actions">
          <button type="button" class="btn theme-toggle" data-controller="theme" data-action="theme#toggle" aria-label="Toggle theme">
            <span class="theme-icon" aria-hidden="true"></span>
          </button>
          <% if current_user.present? %>
            <%= button_to "Sign out", session_path, method: :delete, class: "btn" %>
          <% end %>
        </div>
      </div>
    </header>
    <main class="container">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
