<!DOCTYPE html>
<html lang="en"<%= raw(%( data-theme="#{current_theme}")) if current_theme %>>
  <%= render "layouts/shared/head" %>

  <body>
    <header class="site-header">
      <div class="bar">
        <%= link_to root_path, class: "brand" do %>
          <%= render "shared/brand_mark" %>
          <span>Ledgerly</span>
        <% end %>
        <div class="bar-actions">
          <% if current_user.present? %>
            <%= button_to "Sign out", session_path, method: :delete, class: "btn" %>
          <% end %>
        </div>
      </div>
    </header>
    <main class="container">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <%= render "shared/theme_toggle" %>

    <button type="button" class="scroll-top" data-controller="scroll-top" data-action="scroll-top#top" aria-label="Scroll to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5"/>
        <path d="M5 12l7-7 7 7"/>
      </svg>
    </button>
  </body>
</html>
