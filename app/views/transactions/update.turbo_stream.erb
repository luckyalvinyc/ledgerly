<%= turbo_stream.replace dom_id(@transaction) do %>
  <%= render "shared/transaction",
    transaction: @transaction,
    currency: @bank_account.currency,
    editable: true,
    granularity: @granularity,
    anchor: @period.starts_on %>
<% end %>

<%= turbo_stream.update "pnl_summary" do %>
  <%= render "profit_and_loss/summary", statement: @statement %>
<% end %>

<%= turbo_stream.update "pnl_summary_compact" do %>
  <%= render "profit_and_loss/summary_compact", statement: @statement %>
<% end %>
