<% content_for :title, "Admin sign in" %>

<p class="admin-auth-brand">Ledgerly Admin</p>
<h1 class="page-title">Sign in</h1>

<%= form_with url: admin_session_path do |form| %>
  <div class="field">
    <%= form.label :email %>
    <%= form.email_field :email, value: params[:email], required: true, autocomplete: "username", autofocus: true %>
  </div>
  <div class="field">
    <%= form.label :password %>
    <%= render "shared/password_field", form: form, autocomplete: "current-password" %>
  </div>
  <%= form.submit "Sign in", class: "btn-primary" %>
<% end %>
