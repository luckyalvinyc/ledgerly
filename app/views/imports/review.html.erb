<%= render "shared/crumbs",
  trail: [["Dashboard", root_path], [@import.bank_account.name, @import.bank_account], ["Import", nil]] %>

<h1 class="page-title">Does this look right?</h1>
<p class="muted">Here's what we read from <strong><%= @import.filename %></strong>. Nothing has been saved yet.</p>

<%= render "steps", current: 2 %>

<table class="transactions-table">
  <thead>
    <tr>
      <th class="date">Date</th>
      <th>Description</th>
      <th class="amount">Amount</th>
      <th class="amount">Balance</th>
    </tr>
  </thead>
  <tbody>
    <% @rows.each do |row| %>
      <tr>
        <td class="date"><%= row.posted_on.strftime("%d %b %Y") %></td>
        <td><%= row.description %></td>
        <%= tag.td class: class_names("amount", "is-negative" => row.amount.negative?) do %>
          <%= money(row.amount, currency: @import.bank_account.currency) %>
        <% end %>
        <td class="amount"><%= money(row.balance, currency: @import.bank_account.currency) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<p class="muted">Showing the first <%= @rows.size %> rows.</p>

<details class="format-details">
  <summary>How we read your file</summary>
  <dl>
    <dt>Delimiter</dt>
    <dd><%= @mapping.delimiter %></dd>
    <dt>Amount style</dt>
    <dd><%= @mapping.amount_strategy %></dd>
    <dt>Date format</dt>
    <dd><%= @mapping.date_format %></dd>
  </dl>
  <ul>
    <% @mapping.column_map.each do |field, header| %>
      <li><%= field %>: <strong><%= header %></strong></li>
    <% end %>
  </ul>
</details>

<div class="actions">
  <%= button_to "Yes, import these transactions",
    confirm_import_path(@import),
    class: "btn btn-primary",
    method: :post %>
  <%= link_to "Use a different file",
    new_bank_account_import_path(@import.bank_account),
    class: "btn" %>
</div>
