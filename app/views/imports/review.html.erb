<%= render "shared/crumbs",
  trail: [["Dashboard", root_path], [@import.bank_account.name, @import.bank_account], ["Import", nil]] %>

<h1 class="page-title">Does this look right?</h1>
<p class="muted">Here's what we read from <strong><%= @import.filename %></strong>. If the transactions below look right, import them. Nothing is saved until you do.</p>

<%= render "steps", current: 2 %>

<%= turbo_frame_tag "import_review" do %>
  <% blocked = @rows.count(&:unreadable?) %>
  <% bad_date = @rows.any? { |row| !row.posted_on.ok? } %>
  <% bad_amount = @rows.any? { |row| !row.amount.ok? } %>

  <% if @error.present? %>
    <div class="flash flash-alert"><span><%= @error %></span></div>
  <% end %>

  <%= form_with url: preview_import_path(@import), data: { controller: "auto-submit" } do %>
    <%# Detected once and not worth asking a user about, but carried so they survive a re-read. %>
    <%= hidden_field_tag "mapping[delimiter]", @mapping.delimiter %>
    <%= hidden_field_tag "mapping[date_format]", @mapping.date_format %>
    <%= hidden_field_tag "mapping[amount_strategy]", @mapping.amount_strategy %>
    <%= hidden_field_tag "mapping[column_map][balance]", @mapping.column_map[:balance] %>
    <%= hidden_field_tag "mapping[column_map][reference]", @mapping.column_map[:reference] %>

    <%= tag.details class: "mapping-adjust", open: @adjust_open do %>
      <summary>Adjust how Ledgerly reads your file</summary>

      <p class="muted panel-intro">Tell Ledgerly which column in your file is which. We filled these in by reading your file, so change only what looks wrong. Not sure what a field means? Click the <span class="info-mark" aria-hidden="true">?</span> beside it.</p>

      <% if blocked > 0 %>
        <div class="flash flash-alert"><span>
          <% if bad_date && !bad_amount %>
            We couldn't read the dates. Check that the <strong>Date</strong> column points at your dates.
          <% elsif bad_amount && !bad_date %>
            We couldn't read the amounts. Check the amount columns.
          <% else %>
            We couldn't read the dates or amounts. Check the columns below.
          <% end %>
        </span></div>
      <% end %>

      <div class="mapping-grid">
        <% column_fields(@mapping.amount_strategy).each do |field, label| %>
          <div class="field">
            <%= mapping_label "mapping_column_map_#{field}", label, field %>
            <%= select_tag "mapping[column_map][#{field}]",
              options_for_select([ [ "Not used", "" ] ] + @headers.map { |h| [ h, h ] }, @mapping.column_map[field]),
              data: { action: "change->auto-submit#submit" } %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @rows.none? %>
      <p class="muted">We didn't find any rows in this file.</p>
    <% elsif blocked == @rows.size %>
      <p class="muted">We couldn't read any rows with these settings. Check the <strong>Date</strong> and <strong>Amount</strong> fields above.</p>
    <% else %>
      <table class="transactions-table">
        <thead>
          <tr>
            <th class="date">Date</th>
            <th>Description</th>
            <th class="amount">Amount</th>
            <th class="amount">Balance</th>
          </tr>
        </thead>
        <tbody>
          <% @rows.each do |row| %>
            <%= tag.tr class: class_names("is-unreadable" => row.unreadable?) do %>
              <% date = row.posted_on %>
              <%= tag.td class: class_names("date", "is-bad" => !date.ok?) do %>
                <%= date.ok? ? date.value.strftime("%d %b %Y") : date.value %>
              <% end %>
              <td><%= row.description %></td>
              <% amount = row.amount %>
              <%= tag.td class: class_names("amount", "is-bad" => !amount.ok?, "is-negative" => amount.ok? && amount.value.negative?) do %>
                <%= amount.ok? ? money(amount.value, currency: @import.bank_account.currency) : (amount.value.presence || "—") %>
              <% end %>
              <td class="amount"><%= money(row.balance, currency: @import.bank_account.currency) if row.balance %></td>
            <% end %>
          <% end %>
        </tbody>
      </table>
      <p class="muted">
        Showing the first <%= @rows.size %> rows.
        <% if blocked > 0 %><%= pluralize(blocked, "row") %> can't be read yet and will be skipped.<% end %>
      </p>
    <% end %>

    <div class="actions">
      <%= submit_tag "Yes, import these transactions",
        formaction: confirm_import_path(@import),
        class: "btn btn-primary",
        data: { turbo_frame: "_top", turbo_submits_with: "Importing..." } %>
      <%= link_to "Use a different file",
        new_bank_account_import_path(@import.bank_account),
        class: "btn",
        data: { turbo_frame: "_top" } %>
    </div>
  <% end %>
<% end %>
